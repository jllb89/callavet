{
	"compilerOptions": {
		"target": "ES2020",
		"module": "CommonJS",
		"moduleResolution": "Node",
		"ignoreDeprecations": "6.0",
		"esModuleInterop": true,
		"outDir": "dist",
		"rootDir": "src",
		"declaration": true,
		"strict": true,
		"skipLibCheck": true,
		"composite": true
	},
	"include": ["src/**/*"]
}
